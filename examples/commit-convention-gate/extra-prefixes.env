# examples/commit-convention-gate/extra-prefixes.env
#
# Extend commit-convention-check.sh's allowed prefix set WITHOUT forking the script.
# The standard Conventional Commits types are always allowed:
#   feat fix docs chore refactor test perf build ci style revert
# List any project-specific types here (comma- or whitespace-separated). They are
# ADDED to the standard set, never replace it.
#
# Usage:
#   source examples/commit-convention-gate/extra-prefixes.env
#   bash scripts/commit-convention-check.sh --msg "ops: prune stale branches nightly so that history stays lean"
#
# Or inline for a single invocation:
#   CCC_EXTRA_PREFIX="ops,wip" bash scripts/commit-convention-check.sh --msg "..."

export CCC_EXTRA_PREFIX="ops,wip,merge"
